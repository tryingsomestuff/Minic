#!/bin/bash
ulimit -s unlimited

export CXX=g++
export CC=gcc

if [ -n $EVALFILE ];then
   export EMBEDDEDNNUEPATH=$EVALFILE
else
   export EMBEDDEDNNUENAME=nyctophobic_narwhal.bin
fi

source $(dirname $0)/common
cd_root

FATHOM_PRESENT=0
if [ -e Fathom/src/tbprobe.h ]; then
   FATHOM_PRESENT=1
   echo "found Fathom lib, trying to build"
   $(dirname $0)/buildFathom.sh "$@"
fi

do_title "Building Minic for Linux coverage"

OPT="$d --coverage -fprofile-abs-path -fprofile-update=atomic -O3 $STDVERSION"

if [ $FATHOM_PRESENT = "1" ]; then
   lib=fathom_dev_linux_x64.o
   OPT="$OPT $dir/Fathom/src/$lib -I$dir/Fathom/src"
fi

mkdir -p coverage-dir

rm -f *.gcno
rm -f *.gcda

$CXX $STANDARDSOURCE -ISource -ISource/nnue $OPT -lpthread -DDEBUG_TOOL -o coverage-dir/minic.cov

cd coverage-dir

./minic.cov -analyze "shirov" 25 -minOutputLevel 0
./minic.cov -analyze "fine70" 25 -minOutputLevel 0 -syzygyPath /mnt/BK1/tablebase.sesse.net/syzygy/6/
./minic.cov -perft "start" 6 -minOutputLevel 0
#./minic.cov -evalSpeed Book_and_Test/Tuning/lichess-new-labeled.epd
./minic.cov bench 10 -minOutputLevel 0
./minic.cov -selfplay 5 1 -minOutputLevel 0
./minic.cov -perft_test -minOutputLevel 0
./minic.cov -see_test -minOutputLevel 0
./minic.cov -spsa -minOutputLevel 0
./minic.cov -timeTest 1000 0 20 0 -minOutputLevel 0
./minic.cov -qsearch "start" -minOutputLevel 0
./minic.cov -eval "start" -minOutputLevel 0
./minic.cov -evalHCE "start" -minOutputLevel 0
./minic.cov -gen "start" -minOutputLevel 0
./minic.cov -testmove "start" -minOutputLevel 0
./minic.cov -see "start" e2e4 0 -minOutputLevel 0
./minic.cov -attacked "start" 28 -minOutputLevel 0
./minic.cov -cov "start" 12 -minOutputLevel 0
./minic.cov -kpk "8/8/8/8/8/8/4k1P1/6K1 w - - 0 1" -minOutputLevel 0
./minic.cov -uci -minOutputLevel 0 <<EOF
uci
ucinewgame
isready
setoption name Hash value 16
setoption name Threads value 4
setoption name UCI_Opponent value berserk
setoption name UCI_RatingAdv value 3000
setoption name StyleAttack value 55
setoption name Level value 55
setoption name Hash value 32
setoption name UCI_LimitStrength value true
setoption name UCI_Elo value 1350
setoption name nodesBasedLevel value false
isready
position fen r1bqkb1r/pp3ppp/1np1pn2/6N1/2BP4/8/PPP1QPPP/R1B1K1NR w KQkq - 1 1
go depth 20
wait
position startpos
go mate 2
wait
position startpos
go ponder
ponderhit
wait
stop
debug on
position startpos
go movetime 50
wait
position startpos moves e2e4 e7e5 g1f3 b8c6
go nodes 300
wait
go wtime 2000 btime 2000 winc 20 binc 20 movestogo 20
wait
go infinite
stop
wait
go depth 1 foobar
wait
ucinewgame
position fen 8/2p5/3p4/KP5r/1R3p1k/8/4P1P1/8 w - - 0 1
go depth 6
wait
isready
quit
EOF

./minic.cov -xboard -minOutputLevel 0 <<EOF
xboard
protover 2
post
hard
new
variant fischerandom
setboard rnbqkbnr/pppppppp/8/8/4P3/8/PPPP1PPP/RNBQKBNR b KQkq - 0 1
level 40 5 0
time 500
otim 500
option Hash=64
ping 123
usermove c7c5
undo
remove
?
easy
analyze
