#!/bin/bash
ulimit -s unlimited
set -u

export CXX=g++
export CC=gcc

if [ -n "${EVALFILE:-}" ]; then
   export EMBEDDEDNNUEPATH="$EVALFILE"
else
   export EMBEDDEDNNUENAME=nyctophobic_narwhal.bin
fi

source $(dirname $0)/common
cd_root

FATHOM_PRESENT=0
if [ -e Fathom/src/tbprobe.h ]; then
   FATHOM_PRESENT=1
   echo "found Fathom lib, trying to build"
   $(dirname $0)/buildFathom.sh "$@"
fi

do_title "Building Minic for Linux coverage"

OPT="$d --coverage -fprofile-abs-path -fprofile-update=atomic -O3 $STDVERSION"

if [ $FATHOM_PRESENT = "1" ]; then
   lib=fathom_dev_linux_x64.o
   OPT="$OPT $dir/Fathom/src/$lib -I$dir/Fathom/src"
fi

mkdir -p coverage-dir

rm -f coverage-dir/*.gcno
rm -f coverage-dir/*.gcda
rm -f coverage-dir/*.gcov
rm -rf coverage-dir/rapport
rm -f coverage-dir/rapport.info

rm -f *.gcno
rm -f *.gcda

$CXX $STANDARDSOURCE -ISource -ISource/nnue $OPT -lpthread -DDEBUG_TOOL -o coverage-dir/minic.cov

cd coverage-dir

COV_PROFILE=${COV_PROFILE:-quick}
COV_FAIL_ON_ERROR=${COV_FAIL_ON_ERROR:-0}
SYZYGY_PATH=${SYZYGY_PATH:-/mnt/BK2/tablebase.sesse.net/syzygy/6/}

coverage_errors=0

run_cov() {
   local label="$1"
   shift
   echo "[coverage] $label"
   if ! "$@"; then
      echo "[coverage] command failed: $label"
      coverage_errors=$((coverage_errors + 1))
   fi
}

run_cov_stdin() {
   local label="$1"
   local input="$2"
   shift 2
   echo "[coverage] $label"
   if ! printf "%s\n" "$input" | "$@"; then
      echo "[coverage] command failed: $label"
      coverage_errors=$((coverage_errors + 1))
   fi
}

run_cov "analyze shirov" ./minic.cov -analyze "shirov" 25 -minOutputLevel 0
if [ -d "$SYZYGY_PATH" ]; then
   run_cov "analyze fine70 with syzygy" ./minic.cov -analyze "fine70" 25 -minOutputLevel 0 -syzygyPath "$SYZYGY_PATH"
   run_cov "probe syzygy" ./minic.cov -probe "8/2p5/3p4/KP5r/1R3p1k/8/4P1P1/8 w - - 0 1" -minOutputLevel 0 -syzygyPath "$SYZYGY_PATH"
else
   run_cov "analyze fine70" ./minic.cov -analyze "fine70" 25 -minOutputLevel 0
fi
run_cov "perft start" ./minic.cov -perft "start" 6 -minOutputLevel 0
#./minic.cov -evalSpeed Book_and_Test/Tuning/lichess-new-labeled.epd
run_cov "bench" ./minic.cov bench 10 -minOutputLevel 0
run_cov "selfplay" ./minic.cov -selfplay 5 1 -minOutputLevel 0
run_cov "perft_test" ./minic.cov -perft_test -minOutputLevel 0
run_cov "see_test" ./minic.cov -see_test -minOutputLevel 0
run_cov "spsa" ./minic.cov -spsa -minOutputLevel 0
run_cov "timeTest" ./minic.cov -timeTest 1000 0 20 0 -minOutputLevel 0
run_cov "qsearch" ./minic.cov -qsearch "start" -minOutputLevel 0
run_cov "eval NNUE" ./minic.cov -eval "start" -minOutputLevel 0
run_cov "eval HCE" ./minic.cov -evalHCE "start" -minOutputLevel 0
run_cov "gen" ./minic.cov -gen "start" -minOutputLevel 0
run_cov "testmove" ./minic.cov -testmove "start" -minOutputLevel 0
run_cov "see" ./minic.cov -see "start" e2e4 0 -minOutputLevel 0
run_cov "attacked" ./minic.cov -attacked "start" 28 -minOutputLevel 0
run_cov "cov" ./minic.cov -cov "start" 12 -minOutputLevel 0
run_cov "kpk" ./minic.cov -kpk "8/8/8/8/8/8/4k1P1/6K1 w - - 0 1" -minOutputLevel 0

uci_script=$(cat <<'EOF'
uci
ucinewgame
isready
setoption name Hash value 16
setoption name Threads value 4
setoption name UCI_Opponent value berserk
setoption name UCI_RatingAdv value 3000
setoption name StyleAttack value 55
setoption name Level value 55
setoption name Hash value 32
setoption name UCI_LimitStrength value true
setoption name UCI_Elo value 1350
setoption name nodesBasedLevel value false
isready
position fen r1bqkb1r/pp3ppp/1np1pn2/6N1/2BP4/8/PPP1QPPP/R1B1K1NR w KQkq - 1 1
go depth 20
wait
position startpos
go mate 2
wait
position startpos
go ponder
ponderhit
wait
stop
debug on
position startpos
go movetime 50
wait
position startpos moves e2e4 e7e5 g1f3 b8c6
go nodes 300
wait
go wtime 2000 btime 2000 winc 20 binc 20 movestogo 20
wait
go infinite
stop
wait
go depth 1 foobar
wait
ucinewgame
position fen 8/2p5/3p4/KP5r/1R3p1k/8/4P1P1/8 w - - 0 1
go depth 6
wait
isready
quit
EOF
)
run_cov_stdin "uci protocol" "$uci_script" ./minic.cov -uci -minOutputLevel 0

xboard_script=$(cat <<'EOF'
xboard
protover 2
post
hard
new
variant fischerandom
setboard rnbqkbnr/pppppppp/8/8/4P3/8/PPPP1PPP/RNBQKBNR b KQkq - 0 1
level 40 5 0
time 500
otim 500
option Hash=64
ping 123
usermove c7c5
usermove a2a3
usermove a7a6
undo
remove
?
easy
analyze
exit
nopost
sd 20
go
wait
quit
EOF
)
run_cov_stdin "xboard protocol" "$xboard_script" ./minic.cov -xboard -minOutputLevel 0

if ./minic.cov --help_test -minOutputLevel 0 >/dev/null 2>&1; then
   run_cov "testsuite arasan_sym" ./minic.cov arasan_sym -minOutputLevel 0
fi

if [ "$COV_PROFILE" = "full" ]; then
   run_cov "benchBig" ./minic.cov benchBig 8 -minOutputLevel 0
   run_cov "perft_test_long" ./minic.cov -perft_test_long -minOutputLevel 0
   run_cov "perft_test_long_fischer" ./minic.cov -perft_test_long_fischer -minOutputLevel 0
fi

for file in *.gcno; do
   run_cov "gcov $file" gcov -p $file
done

echo "Checking protocol coverage artifacts ..."
ls -1 minic.cov-uci.gcda minic.cov-xboard.gcda

run_cov "lcov capture" lcov -d "$(pwd)" -b "$(readlink -f ../)" -c -o rapport.info --no-external --ignore-errors negative
run_cov "genhtml" genhtml -o rapport -t "coverage" rapport.info
run_cov "lcov list" lcov -l rapport.info

#rm -f *.gcno
#rm -f *.gcda

ls

if [ "$coverage_errors" -ne 0 ]; then
   echo "Coverage run completed with $coverage_errors failing command(s)."
   if [ "$COV_FAIL_ON_ERROR" = "1" ]; then
      exit 1
   fi
fi

cd ..
